{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/preflight-vanguard.ps1",
            "timeout": 30,
            "statusMessage": "Vanguard pre-flight check"
          }
        ]
      }
    ]
  }
}
